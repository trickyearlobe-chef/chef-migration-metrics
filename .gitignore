# =============================================================================
# Secrets and Credentials (NEVER commit these)
# =============================================================================

# Chef API private keys
*.pem
keys/
deploy/docker-compose/keys/

# Environment files with real credentials
.env
deploy/docker-compose/.env
deploy/elk/.env

# TLS certificates and private keys
*.key
*.crt
*.cert
*.p12
*.pfx

# ACME certificate storage (account keys, issued certs, metadata)
acme/

# =============================================================================
# Runtime and Application Data
# =============================================================================

# PostgreSQL data (Docker Compose local volumes)
pgdata/

# Git clones and cookbook working directories
cookbook_data/

# Export output files
exports/
*.ndjson

# Elasticsearch export staging
elasticsearch/

# ACME runtime data (if stored outside the acme/ pattern above)
.lego/
.certmagic/

