# =============================================================================
# Local Development Runtime Data
# =============================================================================
.local/
deploy/pkg/config.yml

# =============================================================================
# Build Output
# =============================================================================

# Go binary and cross-compiled artifacts
build/
/chef-migration-metrics
*.exe
*.exe~
*.dll
*.so
*.dylib

# nFPM package output
*.rpm
*.deb

# =============================================================================
# Embedded Ruby Environment (built by make build-embedded)
# =============================================================================
# The entire embedded/ tree is a build artifact, covered by build/ above.
# If built outside build/ for any reason:
# NOTE: Use leading / so this only matches the top-level embedded/ directory
# and does NOT match internal/embedded/ (which contains Go source files).
/embedded/

# =============================================================================
# Go
# =============================================================================
# Module vendor directory (if vendoring is used)
vendor/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html
coverage.txt

# Go workspace file
go.work
go.work.sum

# =============================================================================
# Frontend (React / Node.js)
# =============================================================================
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.cache/
frontend/.parcel-cache/
frontend/.next/
frontend/.nuxt/

# TypeScript declaration output (emitDeclarationOnly for project references)
frontend/*.d.ts
frontend/tsconfig.node.tsbuildinfo

# npm / yarn / pnpm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json.bak

