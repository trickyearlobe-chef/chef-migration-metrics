# =============================================================================
# Chef Migration Metrics — Example Configuration
# =============================================================================
# Copy this file to config.yml and edit it for your environment.
#
#   cp config.yml.example config.yml
#
# =============================================================================

# ---------------------------------------------------------------------------
# Chef Server Organisations
# ---------------------------------------------------------------------------
# Add one entry per Chef Infra Server organisation you want to collect from.
organisations:
  - name: my-org
    chef_server_url: https://chef.example.com/organizations/my-org
    org_name: my-org
    client_name: chef-migration-metrics
    client_key_path: /etc/chef-migration-metrics/keys/my-org.pem
    # ssl_verify: true          # Set to false to skip TLS certificate verification
                                 # (e.g. for self-signed certs). Default: true.

  # Additional organisations:
  # - name: another-org
  #   chef_server_url: https://chef.example.com/organizations/another-org
  #   org_name: another-org
  #   client_name: chef-migration-metrics
  #   client_key_path: /etc/chef-migration-metrics/keys/another-org.pem
  #   ssl_verify: false          # Disable TLS verification for this org

  # Database-stored key (requires CMM_CREDENTIAL_ENCRYPTION_KEY env var):
  # - name: staging
  #   chef_server_url: https://chef.example.com/organizations/staging
  #   org_name: staging
  #   client_name: chef-migration-metrics
  #   client_key_credential: staging-key

# ---------------------------------------------------------------------------
# Target Chef Client Versions
# ---------------------------------------------------------------------------
# The versions of Chef Infra Client you are upgrading to. Cookbook
# compatibility is tested against each version listed here.
target_chef_versions:
  - "18.5.0"
  # - "19.0.0"

# ---------------------------------------------------------------------------
# Datastore
# ---------------------------------------------------------------------------
# PostgreSQL connection string. Set via the DATABASE_URL environment variable
# or uncomment and edit the url line below.
# datastore:
#   url: "${DATABASE_URL}"

# ---------------------------------------------------------------------------
# Storage Paths
# ---------------------------------------------------------------------------
# Controls where the application stores downloaded cookbooks and cloned git
# repositories. All paths default to subdirectories under data_dir.
#
# For RPM/DEB installs, data_dir defaults to /var/lib/chef-migration-metrics
# (created by the package with correct ownership). For development, it falls
# back to $TMPDIR/chef-migration-metrics when /var/lib/... doesn't exist.
#
# storage:
#   data_dir: /var/lib/chef-migration-metrics
#   cookbook_cache_dir: /var/lib/chef-migration-metrics/cookbook-cache
#   git_cookbook_dir: /var/lib/chef-migration-metrics/git-cookbooks

# ---------------------------------------------------------------------------
# Git Base URLs (optional)
# ---------------------------------------------------------------------------
# If your cookbooks are in git repositories, list the base URLs here.
# The collector tries each base URL when looking for a cookbook's repo.
# git_base_urls:
#   - https://github.com/my-org
#   - https://gitlab.example.com/chef-cookbooks

# ---------------------------------------------------------------------------
# Collection Schedule
# ---------------------------------------------------------------------------
collection:
  # Cron expression — default: every hour at minute 0.
  schedule: "0 * * * *"
  stale_node_threshold_days: 7
  stale_cookbook_threshold_days: 365

# ---------------------------------------------------------------------------
# Concurrency
# ---------------------------------------------------------------------------
concurrency:
  organisation_collection: 5
  node_page_fetching: 10
  git_pull: 10
  cookstyle_scan: 8
  test_kitchen_run: 4
  readiness_evaluation: 20

# ---------------------------------------------------------------------------
# Readiness
# ---------------------------------------------------------------------------
readiness:
  min_free_disk_mb: 2048

# ---------------------------------------------------------------------------
# Analysis Tools
# ---------------------------------------------------------------------------
# If you installed via the native package (RPM/DEB), CookStyle and Test
# Kitchen are under the embedded prefix. If you are running the standalone
# binary, leave embedded_bin_dir empty to use PATH lookup.
analysis_tools:
  embedded_bin_dir: ""
  # cookstyle_enabled: true     # Set to false to disable CookStyle scanning
                                 # even when the cookstyle binary is available.
  cookstyle_timeout_minutes: 10
  test_kitchen_timeout_minutes: 30

  # Test Kitchen overrides — control the driver, platforms, and architecture
  # used for cookbook compatibility testing. These settings generate a
  # .kitchen.local.yml overlay that overrides the cookbook's own .kitchen.yml.
  #
  # This is especially useful when:
  #   - Cookbook .kitchen.yml files specify the wrong architecture (e.g. x86
  #     boxes but you're running on Apple Silicon / ARM)
  #   - You want to test against the actual OS images used by your fleet
  #   - You need to switch drivers (e.g. from Dokken to Vagrant or vSphere)

  # --- Example: Local Vagrant / VirtualBox (ARM architecture) ---
  # test_kitchen:
  #   driver_override: vagrant
  #   driver_config:
  #     linked_clone: "true"
  #   platform_overrides:
  #     - name: ubuntu-22.04
  #       driver:
  #         box: bento/ubuntu-22.04-arm64
  #     - name: centos-8
  #       driver:
  #         box: bento/centos-8-arm64
  #     - name: windows-2019
  #       driver:
  #         box: my-org/windows-2019-arm64

  # --- Example: Local Vagrant / VirtualBox (x86_64 architecture) ---
  # test_kitchen:
  #   driver_override: vagrant
  #   driver_config:
  #     linked_clone: "true"
  #   platform_overrides:
  #     - name: ubuntu-22.04
  #       driver:
  #         box: bento/ubuntu-22.04
  #     - name: centos-8
  #       driver:
  #         box: bento/centos-8
  #     - name: rhel-9
  #       driver:
  #         box: generic/rhel9

  # --- Example: Docker via Dokken ---
  # test_kitchen:
  #   driver_override: dokken
  #   driver_config:
  #     privileged: "true"
  #   platform_overrides:
  #     - name: ubuntu-22.04
  #       driver:
  #         image: dokken/ubuntu-22.04
  #     - name: centos-8
  #       driver:
  #         image: dokken/centos-8

  # --- Example: VMware vSphere (remote execution) ---
  # test_kitchen:
  #   driver_override: vsphere
  #   driver_config:
  #     host: vcenter.example.com
  #     insecure: "true"
  #   platform_overrides:
  #     - name: ubuntu-22.04
  #       driver:
  #         clone_from: templates/ubuntu-2204-template
  #     - name: rhel-8
  #       driver:
  #         clone_from: templates/rhel-8-template
  #     - name: windows-2019
  #       driver:
  #         clone_from: templates/windows-2019-template

  # --- Example: AWS EC2 ---
  # test_kitchen:
  #   driver_override: ec2
  #   driver_config:
  #     instance_type: t3.medium
  #     region: us-east-1
  #   platform_overrides:
  #     - name: ubuntu-22.04
  #       driver:
  #         image_id: ami-0abcdef1234567890
  #     - name: rhel-8
  #       driver:
  #         image_id: ami-0fedcba0987654321

  # --- Escape hatch for anything not covered above ---
  # test_kitchen:
  #   extra_yaml: |
  #     transport:
  #       name: ssh
  #     verifier:
  #       name: inspec

# ---------------------------------------------------------------------------
# Web Server
# ---------------------------------------------------------------------------
server:
  listen_address: "0.0.0.0"
  port: 8080
  tls:
    mode: "off"
    # mode: "auto"   # Automatic TLS via Let's Encrypt (ACME)
    # mode: "manual"
    # cert_file: /etc/chef-migration-metrics/tls/cert.pem
    # key_file:  /etc/chef-migration-metrics/tls/key.pem
  websocket:
    enabled: true
    max_connections: 100
    send_buffer_size: 64
    write_timeout_seconds: 10
    ping_interval_seconds: 30
    pong_timeout_seconds: 60
  graceful_shutdown_seconds: 30

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
frontend:
  base_path: "/"

# ---------------------------------------------------------------------------
# Exports (optional)
# ---------------------------------------------------------------------------
exports:
  output_directory: /var/lib/chef-migration-metrics/exports
  max_rows: 100000
  async_threshold: 5000
  retention_hours: 24

# ---------------------------------------------------------------------------
# Elasticsearch / NDJSON Export (optional)
# ---------------------------------------------------------------------------
# elasticsearch:
#   enabled: false
#   output_directory: /var/lib/chef-migration-metrics/elasticsearch
#   retention_hours: 48

# ---------------------------------------------------------------------------
# Notifications (optional)
# ---------------------------------------------------------------------------
# notifications:
#   channels:
#     - name: slack-ops
#       type: webhook
#       url_env: SLACK_WEBHOOK_URL
#       events:
#         - collection_complete
#         - readiness_milestone
#     - name: email-team
#       type: email
#       recipients:
#         - chef-team@example.com
#       events:
#         - collection_failed
#         - certificate_expiry_warning

# ---------------------------------------------------------------------------
# SMTP (required for email notifications)
# ---------------------------------------------------------------------------
# smtp:
#   host: smtp.example.com
#   port: 587
#   username_env: SMTP_USERNAME
#   password_env: SMTP_PASSWORD
#   from_address: chef-migration-metrics@example.com
#   tls: true

# ---------------------------------------------------------------------------
# Authentication (optional — defaults to no auth)
# ---------------------------------------------------------------------------
# auth:
#   session_secret_env: CMM_SESSION_SECRET
#   session_lifetime_hours: 24
#   providers:
#     - type: local
#     - type: ldap
#       host: ldap.example.com
#       port: 636
#       base_dn: "ou=users,dc=example,dc=com"
#       bind_dn: "cn=service-account,dc=example,dc=com"
#       bind_password_env: LDAP_BIND_PASSWORD

# ---------------------------------------------------------------------------
# Ownership Tracking (optional)
# ---------------------------------------------------------------------------
# Ownership tracking lets you assign nodes, cookbooks, git repos, roles, and
# policies to owners (teams or individuals) so you can view migration progress
# per owner. Owners can be created via the API/UI; auto-rules below derive
# ownership automatically after each collection run.
#
# ownership:
#   enabled: true                # Default: false. Set true to enable ownership features.
#
#   audit_log:
#     retention_days: 365        # Default: 365. Days to keep audit log entries.
#                                # Set to 0 to retain indefinitely.
#
#   auto_rules:
#     # Assign nodes whose automatic.cloud.provider attribute equals "aws"
#     - name: aws-nodes-to-cloud-team
#       owner: cloud-team
#       type: node_attribute
#       attribute_path: automatic.cloud.provider
#       match_value: "aws"
#
#     # Assign nodes whose name matches a regex pattern
#     - name: web-prod-nodes
#       owner: web-platform
#       type: node_name_pattern
#       pattern: "^web-prod-.*"
#
#     # Assign nodes using a specific policy
#     - name: payment-policy
#       owner: payments-team
#       type: policy_match
#       policy_name: "payment-app"
#
#     # Assign cookbooks whose name matches a regex pattern
#     - name: acme-cookbooks
#       owner: acme-platform
#       type: cookbook_name_pattern
#       pattern: "^acme-.*"
#
#     # Assign git repos whose URL matches a regex pattern
#     - name: web-team-repos
#       owner: web-platform
#       type: git_repo_url_pattern
#       pattern: "gitlab\\.example\\.com/team-web/.*"
#
#     # Assign roles by name (exact or regex pattern)
#     - name: web-server-role
#       owner: web-platform
#       type: role_match
#       pattern: "web-server"
#
#     # Scope a rule to a single organisation (omit to apply across all orgs)
#     - name: staging-nodes
#       owner: platform-team
#       type: node_name_pattern
#       pattern: "^staging-.*"
#       organisation: my-org
#
#     # --- CMDB ownership from node attributes ---
#     # Derive ownership from ITIL CMDB attributes stored on Chef nodes.
#     # A cookbook or wrapper sets normal attributes under itil.cmdb.<object_type>,
#     # for example:
#     #
#     #   node.normal['itil']['cmdb']['node'] = {
#     #     'owner'         => 'linux-platform',
#     #     'ci_id'         => 'CI00123',
#     #     'support_group' => 'L2-Linux',
#     #     'environment'   => 'production'
#     #   }
#     #
#     # The cmdb_attribute rule reads the owner name from the attribute value
#     # at itil.cmdb.<object_type>.<owner_attribute> for each node. Unlike
#     # other rules, the owner field is NOT set in the rule — it is derived
#     # per node from the attribute data.
#
#     # Node ownership — read from itil.cmdb.node.owner
#     - name: cmdb-node-owner
#       type: cmdb_attribute
#       object_type: node
#       # owner_attribute: owner   # Default: "owner". The field within
#                                   # itil.cmdb.<object_type> that holds the
#                                   # owner name.
#
#     # Cookbook ownership — read from itil.cmdb.cookbook.owner
#     - name: cmdb-cookbook-owner
#       type: cmdb_attribute
#       object_type: cookbook
#
#     # InSpec profile ownership — read from itil.cmdb.profile.owner
#     - name: cmdb-profile-owner
#       type: cmdb_attribute
#       object_type: profile
#
#     # Role ownership — read from itil.cmdb.role.owner
#     - name: cmdb-role-owner
#       type: cmdb_attribute
#       object_type: role
#
#     # Use a different field as the owner name (e.g. support_group)
#     - name: cmdb-node-support-group
#       type: cmdb_attribute
#       object_type: node
#       owner_attribute: support_group
#
#     # Scope a CMDB rule to a single organisation
#     - name: cmdb-node-owner-prod
#       type: cmdb_attribute
#       object_type: node
#       organisation: my-org

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
logging:
  level: INFO
