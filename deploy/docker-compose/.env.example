# =============================================================================
# Chef Migration Metrics — Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and edit the values for your environment.
#
#   cp .env.example .env
#
# At minimum, set POSTGRES_PASSWORD to a secure value.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=chef_migration_metrics
POSTGRES_USER=chef_migration_metrics
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# APP_IMAGE controls which container image the app service uses. When set,
# Compose pulls (or uses) this image directly. When left at the default
# "chef-migration-metrics:latest" and the image does not exist locally,
# Compose falls back to building from the root Dockerfile.
APP_IMAGE=chef-migration-metrics:latest
APP_PORT=8080

# Build-time arguments (used only when Compose builds the image).
VERSION=dev
GIT_COMMIT=unknown
BUILD_DATE=unknown

# ---------------------------------------------------------------------------
# Secrets (optional — override values from config.yml)
# ---------------------------------------------------------------------------
# LDAP bind password. Only required if auth.providers includes an LDAP entry.
LDAP_BIND_PASSWORD=

# Credential encryption key. Required when using database-stored Chef API
# keys (client_key_credential). Generate with:
#   openssl rand -base64 32
# CMM_CREDENTIAL_ENCRYPTION_KEY=
