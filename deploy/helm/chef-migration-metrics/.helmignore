# =============================================================================
# .helmignore
# =============================================================================
# Patterns to ignore when building Helm packages with `helm package`.
# This mirrors .gitignore conventions — matching files will not be included
# in the chart archive (.tgz).
# =============================================================================

# =============================================================================
# Version Control
# =============================================================================
.git
.gitignore

# =============================================================================
# AI Assistant Context
# =============================================================================
.claude/

# =============================================================================
# IDE and Editor
# =============================================================================
.vscode/
.idea/
*.iml
*.ipr
*.iws
.zed/
*.swp
*.swo
*~
tags
\#*\#
.#*
*.sublime-project
*.sublime-workspace

# =============================================================================
# Operating System
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
Desktop.ini

# =============================================================================
# Secrets and Credentials (NEVER package into a chart)
# =============================================================================
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
keys/
.env
.env.*
!.env.example

# =============================================================================
# Build Artifacts
# =============================================================================
build/
embedded/
*.rpm
*.deb
*.exe
*.test
*.out

# =============================================================================
# Docker
# =============================================================================
Dockerfile
Dockerfile.*
.dockerignore
docker-compose.yml
docker-compose.override.yml
docker-compose.override.yaml

# =============================================================================
# Documentation (not needed inside the chart archive)
# =============================================================================
CONTRIBUTING.md
CHANGELOG.md
LICENSE

# =============================================================================
# Test and CI Artifacts
# =============================================================================
.kitchen/
.kitchen.local.yml
.rubocop-cache/
.golangci-lint/
junit.xml
test-results/
coverage.html
coverage.txt

# =============================================================================
# Helm chart dependency cache (rebuilt by helm dependency build)
# =============================================================================
charts/*.tgz
