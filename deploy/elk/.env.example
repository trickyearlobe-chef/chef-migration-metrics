# ELK Testing Stack — Environment Variables
#
# Copy this file to .env and adjust values as needed.
#
#   cp .env.example .env
#
# All variables have sensible defaults for local development and testing.
# See deploy/elk/README.md for full instructions.

# ---------------------------------------------------------------------------
# ELK Stack Version
# ---------------------------------------------------------------------------
# All three services (Elasticsearch, Logstash, Kibana) use the same version.
ELK_VERSION=8.17.0

# ---------------------------------------------------------------------------
# Elasticsearch
# ---------------------------------------------------------------------------
# Host port for the Elasticsearch HTTP API.
ELASTICSEARCH_PORT=9200

# Name of the Elasticsearch index that Logstash writes to.
ELASTICSEARCH_INDEX=chef-migration-metrics

# JVM heap size for Elasticsearch. For local testing 512m is usually enough.
# Increase for larger data sets.
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ---------------------------------------------------------------------------
# Logstash
# ---------------------------------------------------------------------------
# Host port for the Logstash monitoring API.
LOGSTASH_MONITORING_PORT=9600

# JVM heap size for Logstash.
LS_JAVA_OPTS=-Xms256m -Xmx256m

# ---------------------------------------------------------------------------
# Kibana
# ---------------------------------------------------------------------------
# Host port for the Kibana web UI.
KIBANA_PORT=5601

# Encryption key for Kibana saved objects. Must be at least 32 characters.
# Change this if you plan to persist Kibana dashboards across restarts.
KIBANA_ENCRYPTION_KEY=a]V3:B6s#K9m!Pq2x8Yz@wR5fT7hJ0nL
